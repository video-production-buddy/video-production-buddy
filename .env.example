# Video Production Buddy - local API keys and model defaults
#
# How beginners should use this file:
# 1. Copy this template to a local file named .env.
# 2. Fill only the API keys you plan to use. Leave everything else blank.
# 3. Optional: set the VPB_* model defaults beside the matching key.
# 4. Run:
#      make preflight
#      make models-list
#      make models-check ENV_FILE=.env
#
# .env is ignored by git. Do not commit real keys.
# Empty VPB_* model settings mean: auto-select a provider/model at runtime.
# If you only set API keys, provider tools still use their built-in default models.
# Explicit provider/model values in a prompt or tool input still win.


# ---------------------------------------------------------------------------
# Capability-level model defaults (optional)
# ---------------------------------------------------------------------------
# Use these only after you add the matching provider key below.
# To find valid values for your currently configured keys:
#   make models-list
#   make models-list CAPABILITY=video_generation
#
# Common capabilities:
# - video_generation: generated video providers
# - image_generation: generated image providers
# - tts: text-to-speech providers
# - music_generation: music providers
# - text_generation: optional paid LLM helper tools
# - transcription: speech-to-text providers

VPB_VIDEO_GENERATION_PROVIDER=      # e.g. bailian | minimax | seedance | kling | veo | runway | higgsfield | heygen
VPB_VIDEO_GENERATION_MODEL=         # e.g. MiniMax-Hailuo-2.3 | happyhorse-1.1-t2v | seedance2 | veo3.1/fast

VPB_IMAGE_GENERATION_PROVIDER=      # e.g. bailian | dashscope | flux | openai | recraft | grok
VPB_IMAGE_GENERATION_MODEL=         # e.g. qwen-image-2.0-pro | gpt-image-2 | flux-2-pro | v4.1

VPB_TTS_PROVIDER=                   # e.g. minimax | bailian | openai | google_tts | elevenlabs | piper
VPB_TTS_MODEL=                      # e.g. speech-2.8-hd | qwen3-tts-flash | eleven_v3

VPB_MUSIC_GENERATION_PROVIDER=      # e.g. minimax | suno | elevenlabs
VPB_MUSIC_GENERATION_MODEL=         # e.g. music-2.6 | music-2.6-free

VPB_TEXT_GENERATION_PROVIDER=       # e.g. minimax | bailian
VPB_TEXT_GENERATION_MODEL=          # e.g. MiniMax-M3 | qwen3.7-plus

VPB_TRANSCRIPTION_PROVIDER=         # e.g. bailian
VPB_TRANSCRIPTION_MODEL=            # e.g. qwen3-asr-flash

# Advanced: leave blank unless you want auto-selection limited to a shortlist.
# Examples:
#   VPB_VIDEO_GENERATION_ALLOWED_PROVIDERS=seedance,veo,kling
#   VPB_IMAGE_GENERATION_ALLOWED_PROVIDERS=bailian,openai,flux
#   VPB_TTS_ALLOWED_PROVIDERS=minimax,bailian,elevenlabs,piper
VPB_VIDEO_GENERATION_ALLOWED_PROVIDERS=
VPB_IMAGE_GENERATION_ALLOWED_PROVIDERS=
VPB_TTS_ALLOWED_PROVIDERS=
VPB_MUSIC_GENERATION_ALLOWED_PROVIDERS=
VPB_TEXT_GENERATION_ALLOWED_PROVIDERS=
VPB_TRANSCRIPTION_ALLOWED_PROVIDERS=


# ---------------------------------------------------------------------------
# Broad image/video gateways
# ---------------------------------------------------------------------------

# fal.ai - one pay-as-you-go key for FLUX/Recraft images and several video models.
FAL_KEY=                            # Get one at https://fal.ai/dashboard/keys
FAL_AI_API_KEY=                     # Optional fal.ai alias used by several provider tools
# If using this key for video, inspect:
#   make models-list CAPABILITY=video_generation
# Common routes include Seedance, Kling, Veo, and MiniMax through provider tools.

# Alibaba Cloud Bailian / DashScope - Qwen speech/ASR, Wan video, Wanxiang image.
DASHSCOPE_API_KEY=                  # Get one at https://bailian.console.aliyun.com/
DASHSCOPE_WORKSPACE_ID=             # Required for qwen-image-2.0-pro image generation.
DASHSCOPE_REGION=cn-beijing         # Qwen Image endpoint region. Use ap-southeast-1 for Singapore workspaces.
# Unlocks: dashscope_image, dashscope_tts, dashscope_asr, cosyvoice_tts, qwen_asr, wan_video_api, wanx_image, qwen_chat, qwen_vl.
# Project-known defaults if you choose Bailian (verified against public docs 2026-06-28):
#   video: happyhorse-1.1-t2v
#   image: qwen-image-2.0-pro with workspace settings, otherwise wan2.7-image-pro
#   TTS:   qwen3-tts-flash
#   ASR:   qwen3-asr-flash
#   text:  qwen3.7-plus
# Example:
#   VPB_VIDEO_GENERATION_PROVIDER=bailian
#   VPB_VIDEO_GENERATION_MODEL=happyhorse-1.1-t2v
#   VPB_IMAGE_GENERATION_PROVIDER=bailian
#   VPB_IMAGE_GENERATION_MODEL=qwen-image-2.0-pro
#   VPB_TTS_PROVIDER=bailian
#   VPB_TTS_MODEL=qwen3-tts-flash

# Google - Gemini/Nano Banana images, Imagen images, and Google Cloud TTS.
GOOGLE_API_KEY=                     # Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=                     # Optional Google AI Studio alias accepted by Google image/TTS tools
# Alternative to API key: service-account JSON auth.
GOOGLE_APPLICATION_CREDENTIALS=     # Path to a service-account JSON key file
GOOGLE_CLOUD_PROJECT=               # GCP project id, required for Imagen via Vertex AI
# GOOGLE_CLOUD_PROJECT_ID and GCLOUD_PROJECT are accepted fallbacks; prefer GOOGLE_CLOUD_PROJECT.
GOOGLE_CLOUD_LOCATION=              # Vertex AI region, default us-central1


# ---------------------------------------------------------------------------
# Voice, speech, and narration
# ---------------------------------------------------------------------------

ELEVENLABS_API_KEY=                 # TTS narration (default eleven_v3), music generation, sound effects

OPENAI_API_KEY=                     # OpenAI TTS fallback and GPT Image generation (default gpt-image-2)

XAI_API_KEY=                        # Grok image/video generation (defaults: grok-imagine-image-quality, grok-imagine-video for text/reference video)

DOUBAO_SPEECH_API_KEY=              # Volcengine Doubao Speech TTS new-console API key
DOUBAO_SPEECH_VOICE_TYPE=           # Default Doubao speaker, e.g. zh_female_vv_uranus_bigtts

# Piper local voices do not require env vars; install piper-tts via pip.


# ---------------------------------------------------------------------------
# MiniMax - video, TTS, music, and optional text helper
# ---------------------------------------------------------------------------

MINIMAX_API_KEY=                    # Get one from Account > API Keys: https://platform.minimax.io/docs/guides/quickstart-preparation
MINIMAX_API_BASE=                   # Optional overseas host: https://api.minimax.io/v1
# Note: music-2.6 / music-cover require a paid Token Plan.
# Project-known defaults if you choose MiniMax:
#   video: MiniMax-Hailuo-2.3
#   image-to-video model options are listed by `make models-list CAPABILITY=video_generation`
#   TTS: speech-2.8-hd
#   music: music-2.6
#   text: MiniMax-M3
# Example:
#   VPB_VIDEO_GENERATION_PROVIDER=minimax
#   VPB_VIDEO_GENERATION_MODEL=MiniMax-Hailuo-2.3
#   VPB_TTS_PROVIDER=minimax
#   VPB_TTS_MODEL=speech-2.8-hd
#   VPB_MUSIC_GENERATION_PROVIDER=minimax
#   VPB_MUSIC_GENERATION_MODEL=music-2.6


# ---------------------------------------------------------------------------
# Dedicated video providers and gateways
# ---------------------------------------------------------------------------

HEYGEN_API_KEY=                     # HeyGen API, including VEO/Sora/Runway/Kling/Seedance gateway routes

RUNWAY_API_KEY=                     # Runway direct API: Seedance 2, Gen-4.5, Veo 3.1, etc.
RUNWAYML_API_SECRET=                # Optional Runway API secret alias accepted by runway_video

REPLICATE_API_TOKEN=                # Replicate-hosted Seedance provider
# Seedance model examples: standard, fast

HIGGSFIELD_API_KEY=                 # Higgsfield Cloud API key
HIGGSFIELD_API_SECRET=              # Higgsfield Cloud API secret
HIGGSFIELD_KEY=                     # Optional combined Higgsfield key:secret value

VIDEO_GEN_LOCAL_ENABLED=            # Set to true for local video gen, requires GPU + diffusers
# Local model examples: wan2.1-1.3b, wan2.1-14b, hunyuan-1.5, ltx2-local, cogvideo-5b, cogvideo-2b
VIDEO_GEN_LOCAL_MODEL=

MODAL_LTX2_ENDPOINT_URL=            # Modal self-hosted LTX-2 endpoint, optional


# ---------------------------------------------------------------------------
# Music
# ---------------------------------------------------------------------------

SUNO_API_KEY=                       # Suno AI music generation
FREESOUND_API_KEY=                  # Freesound music/sound search fallback


# ---------------------------------------------------------------------------
# Stock media and public archives
# ---------------------------------------------------------------------------

PEXELS_API_KEY=                     # Pexels stock footage/images, free
PIXABAY_API_KEY=                    # Pixabay stock footage/images, free
UNSPLASH_ACCESS_KEY=                # Unsplash stock images, free developer key
COVERR_API_KEY=                     # Optional Coverr stock video higher-rate/pro access
VIDEVO_API_KEY=                     # Optional Videvo stock video search
NASA_API_KEY=                       # Optional NASA higher-rate public media access
NARA_API_KEY=                       # Optional NARA higher-rate public media access
POND5_API_KEY=                      # Optional Pond5 public-domain stock access


# ---------------------------------------------------------------------------
# Analysis and local runtime tuning
# ---------------------------------------------------------------------------

HF_TOKEN=                           # HuggingFace token; enables speaker diarization in transcriber

VIDEO_PRODUCTION_BUDDY_CACHE_DIR=   # Optional clip/media cache override
VIDEO_PRODUCTION_BUDDY_CACHE_MAX_GB= # Optional cache size limit in GB
SUBTITLE_ALIGNER_DEVICE=            # Optional subtitle alignment device, e.g. cpu or cuda
VPB_ALLOW_BROWSER_OPEN=             # Set 0/false to stop GenUI opening a browser automatically


# ---------------------------------------------------------------------------
# Avatar tools, local installs
# ---------------------------------------------------------------------------

# WAV2LIP_PATH=                     # Path to cloned Wav2Lip repo for lip sync
# SADTALKER_PATH=                   # Path to cloned SadTalker repo for talking head avatars
