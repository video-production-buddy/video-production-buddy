{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/artifacts/ui_form_config",
  "title": "GenUI Form Config",
  "description": "Project-specific visual form configuration generated by the agent for a human interaction gate. The form collects choices only; it never writes canonical pipeline artifacts directly.",
  "type": "object",
  "required": [
    "version",
    "config_id",
    "project_id",
    "pipeline_type",
    "stage",
    "gate",
    "title",
    "sections",
    "submit_actions"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "config_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+$",
      "description": "Stable id for this generated form configuration."
    },
    "project_id": { "type": "string", "minLength": 1 },
    "pipeline_type": { "type": "string", "minLength": 1 },
    "stage": { "type": "string", "minLength": 1 },
    "gate": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    },
    "submit_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/submit_action" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["id", "title", "fields"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "field": {
      "type": "object",
      "required": ["id", "label", "type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "label": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "textarea",
            "select",
            "radio",
            "multiselect",
            "checkbox",
            "number",
            "file_path",
            "url",
            "approval",
            "info_card"
          ]
        },
        "required": { "type": "boolean", "default": false },
        "default": {},
        "recommended": { "type": "string" },
        "help_text": { "type": "string" },
        "placeholder": { "type": "string" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "binding": { "$ref": "#/$defs/binding" },
        "choices": {
          "type": "array",
          "items": { "$ref": "#/$defs/choice" }
        }
      }
    },
    "binding": {
      "type": "object",
      "required": ["artifact", "path"],
      "additionalProperties": false,
      "properties": {
        "artifact": { "type": "string", "minLength": 1 },
        "path": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_]+(\\.[A-Za-z0-9_]+)*$",
          "description": "Dotted artifact path the agent will map after reviewing ui_response."
        }
      }
    },
    "choice": {
      "type": "object",
      "required": ["value", "label"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "recommended": { "type": "boolean", "default": false }
      }
    },
    "submit_action": {
      "type": "object",
      "required": ["id", "label", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "label": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["submit", "approve", "revise", "abort"]
        },
        "recommended": { "type": "boolean", "default": false }
      }
    }
  }
}
