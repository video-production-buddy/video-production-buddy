{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "video-production-buddy/artifacts/edit_decisions",
  "title": "Edit Decisions",
  "description": "Editorial decisions produced by the Edit Agent.",
  "type": "object",
  "required": ["version", "cuts", "render_runtime"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "music_strategy": {
      "type": "string",
      "enum": ["generative_loose", "library_locked", "search_align", "none"],
      "description": "Music strategy copied from production_proposal. Use 'none' to make an approved no-background-music edit explicit; music-backed ad edits must include audio.music.volume_schedule."
    },
    "cuts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "in_seconds", "out_seconds"],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string", "description": "Source file path, asset-manifest ID, or 'remotion:<component>' for Remotion-native cards (e.g. remotion:tagline_card, remotion:brand_outro_card)" },
          "in_seconds": { "type": "number", "minimum": 0 },
          "out_seconds": { "type": "number", "minimum": 0 },
          "maps_to_beat": {
            "type": "string",
            "description": "Production-bible beat id this cut realizes. Required by ad-video contextual validation."
          },
          "beat_id": {
            "type": "string",
            "description": "Alias for maps_to_beat when upstream artifacts use beat_id naming."
          },
          "beat": {
            "type": "string",
            "description": "Human-readable beat label copied from scene_plan.scenes[].beat when no beat_id is available."
          },
          "speed": { "type": "number", "minimum": 0.1, "default": 1.0 },
          "layer": {
            "type": "string",
            "enum": ["primary", "overlay", "background"],
            "default": "primary"
          },
          "transform": {
            "type": "object",
            "properties": {
              "scale": { "type": "number", "minimum": 0, "default": 1.0 },
              "position": { "type": "string", "default": "center" },
              "animation": {
                "type": "string",
                "description": "Motion applied to still images (e.g. ken-burns-slow-zoom, pan-left, static)"
              },
              "crop": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "width": { "type": "number" },
                  "height": { "type": "number" }
                }
              }
            },
            "additionalProperties": false
          },
          "transition_in": {
            "type": "string",
            "description": "Transition type entering this cut (e.g. fade, dissolve, cut, wipe)"
          },
          "transition_out": {
            "type": "string",
            "description": "Transition type leaving this cut"
          },
          "transition_duration": {
            "type": "number",
            "minimum": 0,
            "description": "Duration of transition in seconds"
          },
          "reason": { "type": "string" },
          "hero": {
            "type": "boolean",
            "description": "True if this cut is a visual peak deserving extra render attention"
          },
          "vfx_note": {
            "type": "string",
            "description": "VFX or post-processing note (e.g. frost-wave overlay fallback instructions)"
          },
          "type": {
            "type": "string",
            "description": "Remotion scene component type: text_card, stat_card, anime_scene, hero_title, callout, comparison, terminal_scene, bar_chart, line_chart, pie_chart, kpi_grid, progress_bar"
          },
          "text": { "type": "string", "description": "Primary text for text_card / hero_title scenes" },
          "stat": { "type": "string", "description": "Statistic value for stat_card scenes" },
          "subtitle": { "type": "string", "description": "Subtitle text for stat_card scenes" },
          "heroSubtitle": { "type": "string", "description": "Subtitle for hero_title scenes" },
          "accentColor": { "type": "string", "description": "Accent color override (hex)" },
          "backgroundColor": { "type": "string", "description": "Background color override (hex)" },
          "color": { "type": "string", "description": "Text color override (hex)" },
          "fontSize": { "type": "integer", "description": "Font size override for Remotion scenes" },
          "animation": { "type": "string", "description": "Animation style (e.g. ken-burns, rapid_spring_entry)" },
          "images": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Image paths for anime_scene cuts"
          },
          "vignette": { "type": "boolean", "description": "Apply vignette overlay to anime_scene" },
          "particles": { "type": "string", "description": "Particle effect type for anime_scene" },
          "particleColor": { "type": "string" },
          "particleCount": { "type": "integer" },
          "particleIntensity": { "type": "number" },
          "backgroundImage": { "type": "string", "description": "AI image rendered behind a Remotion component" },
          "screenshotSize": {
            "$ref": "#/$defs/screenshot_size",
            "description": "Natural pixel size of backgroundImage for screenshot_scene overlay coordinate mapping."
          },
          "cursorStartAt": {
            "$ref": "#/$defs/screenshot_point",
            "description": "Starting cursor position for screenshot_scene as normalized [x, y]."
          },
          "screenshotSteps": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/screenshot_step" },
            "description": "Scripted overlay/cursor actions for screenshot_scene."
          },
          "backgroundVideo": { "type": "string", "description": "Video clip rendered behind a Remotion component" },
          "backgroundVideoStart": { "type": "number", "minimum": 0 },
          "backgroundOverlay": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_in_seconds": { "type": "number", "minimum": 0, "description": "Seek point within source video" },
          "title": { "type": "string" },
          "callout_type": { "type": "string", "enum": ["info", "warning", "tip", "quote"] },
          "leftLabel": { "type": "string" },
          "rightLabel": { "type": "string" },
          "leftValue": { "type": "string" },
          "rightValue": { "type": "string" },
          "leftSubLabel": { "type": "string" },
          "rightSubLabel": { "type": "string" },
          "drawDelay": { "type": "number", "minimum": 0 },
          "chartData": { "type": "array" },
          "chartSeries": { "type": "array" },
          "chartColors": { "type": "array", "items": { "type": "string" } },
          "chartAnimation": { "type": "string" },
          "donut": { "type": "boolean" },
          "centerLabel": { "type": "string" },
          "centerValue": { "type": "string" },
          "showGrid": { "type": "boolean" },
          "showValues": { "type": "boolean" },
          "showLegend": { "type": "boolean" },
          "showMarkers": { "type": "boolean" },
          "xLabel": { "type": "string" },
          "yLabel": { "type": "string" },
          "columns": { "type": "integer", "enum": [2, 3, 4] },
          "progress": { "type": "number" },
          "progressLabel": { "type": "string" },
          "progressColor": { "type": "string" },
          "progressAnimation": { "type": "string" },
          "progressSegments": { "type": "array" },
          "steps": { "type": "array", "description": "Terminal scene steps" },
          "terminalTitle": { "type": "string" },
          "prompt": { "type": "string" },
          "lightingFrom": { "type": "string" },
          "lightingTo": { "type": "string" },
          "badgeStart": { "type": "number" },
          "badgeEnd": { "type": "number" },
          "badgeColor": { "type": "string" },
          "banners": { "type": "array", "items": { "type": "string" } },
          "toastText": { "type": "string" },
          "toastDelay": { "type": "number", "minimum": 0 },
          "sidebarItems": { "type": "array", "items": { "type": "string" } },
          "panelTitle": { "type": "string" },
          "brandName": { "type": "string" },
          "tagline": { "type": "string" },
          "ctaText": { "type": "string" },
          "productImage": { "type": "string", "description": "Approved product reference image rendered by product-visible Remotion scenes such as creator_workflow_scene and brand_card." },
          "hardwareTreatment": {
            "type": "string",
            "enum": ["synthetic_laptop"],
            "description": "Explicit opt-in for synthetic hardware treatment. Omit unless the user approved a generic laptop packshot; productImage always takes precedence."
          },
          "label": { "type": "string" },
          "tabCount": { "type": "number" },
          "showKeyboardPill": { "type": "boolean" },
          "keyShortcut": { "type": "string" },
          "startCount": { "type": "number" },
          "endCount": { "type": "number" },
          "freezeAtSeconds": { "type": "number", "minimum": 0 },
          "showThumb": { "type": "boolean" },
          "targetValue": { "type": "number" },
          "unitLabel": { "type": "string" },
          "rollDurationSeconds": { "type": "number", "minimum": 0 },
          "styleLayers": { "type": "array", "items": { "type": "object" } }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "const": "screenshot_scene" }
              },
              "required": ["type"]
            },
            "then": {
              "required": ["backgroundImage", "screenshotSteps"]
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "overlays": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "start_seconds", "end_seconds", "position"],
        "properties": {
          "asset_id": { "type": "string" },
          "start_seconds": { "type": "number", "minimum": 0 },
          "end_seconds": { "type": "number", "minimum": 0 },
          "position": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" }
            },
            "required": ["x", "y"]
          },
          "animation": { "type": "string" },
          "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "audio": {
      "type": "object",
      "description": "Audio configuration for narration, music, and SFX.",
      "properties": {
        "narration": {
          "type": "object",
          "description": "Narration config. Use 'src' for a pre-mixed audio file, or 'segments' for individual per-beat clips.",
          "properties": {
            "src": { "type": "string", "description": "Path to pre-mixed narration audio file (AAC/MP3/WAV)" },
            "volume": { "type": "number", "minimum": 0, "maximum": 2.0, "default": 1.0 },
            "segments": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["asset_id", "start_seconds"],
                "properties": {
                  "asset_id": { "type": "string" },
                  "start_seconds": { "type": "number", "minimum": 0 },
                  "end_seconds": { "type": "number", "minimum": 0 }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "music": {
          "type": "object",
          "properties": {
            "asset_id": { "type": "string" },
            "volume": { "type": "number", "minimum": 0, "maximum": 1 },
            "fade_in_seconds": { "type": "number", "minimum": 0 },
            "fade_out_seconds": { "type": "number", "minimum": 0 },
            "ducking": {
              "oneOf": [
                { "type": "boolean" },
                {
                  "type": "object",
                  "properties": {
                    "enabled": { "type": "boolean", "default": true },
                    "threshold_db": { "type": "number" },
                    "reduction_db": { "type": "number" },
                    "attack_ms": { "type": "number", "minimum": 0 },
                    "release_ms": { "type": "number", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              ]
            },
            "volume_schedule": {
              "type": "array",
              "description": "Time-indexed music gain envelope produced by lib.intensity_curve.derive_duck_schedule from production_bible.narrative.intensity_curve and the narration windows. When present, audio_mixer applies this envelope on top of (or in place of) the static ducking config so the duck depth tracks the emotional arc — quieter beats duck deeper, peak beats duck shallower. Optional; absence preserves the legacy flat-duck path.",
              "items": {
                "type": "object",
                "required": ["t_seconds", "gain_db"],
                "properties": {
                  "t_seconds": { "type": "number", "minimum": 0 },
                  "gain_db": { "type": "number" }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "sfx": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "asset_id": { "type": "string" },
              "start_seconds": { "type": "number", "minimum": 0 },
              "volume": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "subtitles": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "style": { "type": "string", "description": "Display style: sentence, word-by-word, karaoke" },
        "source": { "type": "string", "description": "Path to subtitle file or asset ID" },
        "font": { "type": "string" },
        "font_size": { "type": "integer" },
        "color": { "type": "string", "description": "Primary text color (hex or ASS format)" },
        "outline_color": { "type": "string" },
        "background": { "type": "string", "description": "Background color with optional alpha (e.g. #00000088)" },
        "position": { "type": "string", "enum": ["top-center", "bottom-center"], "default": "bottom-center", "description": "Subtitle vertical placement. bottom-center = ASS Alignment=2, lower edge of frame. top-center = ASS Alignment=8, upper edge. The value 'center' has been removed — it mapped to ASS Alignment=5 (vertical midpoint), blocking content." },
        "max_words_per_line": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "music": {
      "type": "object",
      "description": "Legacy top-level music config. Prefer audio.music for new pipelines.",
      "properties": {
        "asset_id": { "type": "string" },
        "volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "ducking": { "type": "boolean", "default": true },
        "fade_in_seconds": { "type": "number", "minimum": 0 },
        "fade_out_seconds": { "type": "number", "minimum": 0 }
      }
    },
    "transitions": {
      "type": "array",
      "description": "Global transition list. Per-cut transitions in cuts[].transition_in/out are preferred.",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "at_seconds": { "type": "number" },
          "duration_seconds": { "type": "number", "minimum": 0 }
        },
        "required": ["type", "at_seconds", "duration_seconds"]
      }
    },
    "derivative_specs": {
      "type": "object",
      "description": "Per-variant edit instructions for derivative renders opted in at proposal. Keys are variant IDs such as '9:16', '1:1', '15s_short', or cross-product variants.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "crop_regions": {
            "description": "Either the literal string 'from_scene_plan' or a variant-specific crop-region map copied from scene_plan.",
            "oneOf": [
              { "type": "string", "const": "from_scene_plan" },
              { "type": "object", "minProperties": 1 }
            ]
          },
          "subtitle_style_override": { "type": "object" },
          "include_scenes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "total_duration_check": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "renderer_family": {
      "type": "string",
      "enum": ["explainer-data", "explainer-teacher", "cinematic-trailer", "documentary-montage", "product-reveal", "screen-demo", "presenter", "animation-first"],
      "description": "Locked at proposal stage — creative grammar for this deliverable. Preserved from production_proposal.render_runtime context for ad-video or the legacy proposal-packet runtime context for older pipelines; edit MUST NOT change without a logged decision."
    },
    "render_runtime": {
      "type": "string",
      "enum": ["remotion", "hyperframes", "ffmpeg"],
      "description": "Locked at proposal stage — technical runtime that realizes renderer_family. Edit MUST carry this forward unchanged unless a logged render_runtime_selection decision overrides it."
    },
    "composition_mode": {
      "type": "string",
      "enum": ["templated", "atelier"],
      "description": "Locked at proposal — HOW the composition is built. Edit MUST carry forward unchanged. 'atelier' routes video_compose to _render_via_atelier (no cut-schema, no stock registry); requires `bespoke` block below."
    },
    "bespoke": {
      "type": "object",
      "description": "Required when composition_mode='atelier'. Contract for the hand-authored, project-local Remotion render. See tools/video/video_compose.py → _render_via_atelier docstring.",
      "required": ["entry", "composition_id", "art_direction"],
      "properties": {
        "entry": { "type": "string", "description": "Path to the project-local Remotion entry .tsx (typically projects/<slug>/index.tsx). If outside remotion-composer/, auto-staged via directory junction/symlink at render time." },
        "composition_id": { "type": "string", "description": "id registered in that entry's Root" },
        "art_direction": { "type": "string", "description": "Short commitment to a fresh visual language (or a path to art-direction.md). REQUIRED — enforced by _run_atelier_checks." },
        "props_path": { "type": "string", "description": "Absolute path to a props JSON (Remotion --props)" },
        "public_dir": { "type": "string", "description": "Per-project public dir (avoids copying the bloated shared remotion-composer/public/)" },
        "scale": { "type": "number", "minimum": 0.1, "maximum": 1.0 },
        "crf": { "type": "integer", "minimum": 0, "maximum": 51 },
        "concurrency": { "type": "integer", "minimum": 1 }
      }
    },
    "slideshow_risk_score": {
      "type": "object",
      "description": "Slideshow risk assessment from lib/slideshow_risk.py",
      "properties": {
        "average": { "type": "number" },
        "verdict": { "type": "string", "enum": ["strong", "acceptable", "revise", "fail"] }
      }
    },
    "metadata": { "type": "object" },
    "total_duration_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "Target output duration in seconds. Must match render_runtime composition length."
    }
  },
  "$defs": {
    "screenshot_point": {
      "type": "array",
      "prefixItems": [
        { "type": "number", "minimum": 0, "maximum": 1 },
        { "type": "number", "minimum": 0, "maximum": 1 }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "screenshot_region": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "w": { "type": "number", "minimum": 0, "maximum": 1 },
        "h": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "screenshot_size": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "screenshot_step": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "cursor_move" } } },
          "then": { "required": ["to"] }
        },
        {
          "if": { "properties": { "kind": { "const": "click_pulse" } } },
          "then": { "required": ["at"] }
        },
        {
          "if": { "properties": { "kind": { "const": "type_into" } } },
          "then": { "required": ["region", "text"] }
        },
        {
          "if": { "properties": { "kind": { "const": "bubble_append" } } },
          "then": { "required": ["region", "text"] }
        },
        {
          "if": { "properties": { "kind": { "const": "typing_dots" } } },
          "then": { "required": ["at"] }
        },
        {
          "if": { "properties": { "kind": { "const": "highlight_box" } } },
          "then": { "required": ["region"] }
        },
        {
          "if": { "properties": { "kind": { "const": "callout_balloon" } } },
          "then": { "required": ["anchor", "text"] }
        },
        {
          "if": { "properties": { "kind": { "const": "pause" } } },
          "then": { "required": ["seconds"] }
        }
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "cursor_move",
            "click_pulse",
            "type_into",
            "bubble_append",
            "typing_dots",
            "highlight_box",
            "callout_balloon",
            "pause"
          ]
        },
        "to": { "$ref": "#/$defs/screenshot_point" },
        "at": { "$ref": "#/$defs/screenshot_point" },
        "anchor": { "$ref": "#/$defs/screenshot_point" },
        "region": { "$ref": "#/$defs/screenshot_region" },
        "text": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "position": { "type": "string", "enum": ["top", "bottom", "left", "right"] },
        "durationSeconds": { "type": "number", "minimum": 0 },
        "seconds": { "type": "number", "minimum": 0 },
        "typeSpeed": { "type": "number", "exclusiveMinimum": 0 },
        "fontSize": { "type": "number", "exclusiveMinimum": 0 },
        "color": { "type": "string" },
        "stream": { "type": "boolean" },
        "pulses": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "additionalProperties": false
}
