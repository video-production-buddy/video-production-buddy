{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/artifacts/scene_plan",
  "title": "Scene Plan",
  "description": "Ordered scene list produced by the Scene Planner agent.",
  "type": "object",
  "required": ["version", "scenes"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "style_playbook": { "type": "string", "description": "Name of the active style playbook" },
    "style_mode": {
      "type": "string",
      "enum": ["animated", "cinematic"],
      "description": "Render mode locked at proposal. Carried into scene_plan so scene/asset directors can branch on it without re-reading production_proposal."
    },
    "total_duration_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "Total scene-plan duration; should match the sum of scenes[].end_seconds and equal script.total_duration within ±0.5s."
    },
    "derivative_variants": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["9:16", "1:1", "15s", "15s_short"]
      },
      "uniqueItems": true,
      "description": "Variant ids (e.g. '9:16', '1:1', '15s_short') the user opted into at proposal. Aspect-ratio variants require per-scene crop_regions; duration-only variants are handled by core-scene filtering. Mirrors production_proposal.derivatives_added."
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "description", "start_seconds", "end_seconds"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["talking_head", "broll", "animation", "character_scene", "diagram", "text_card", "transition", "generated", "screen_recording"]
          },
          "description": { "type": "string" },
          "emotional_target": {
            "type": "string",
            "description": "The intended emotional register for this scene, copied from the matching beat in production_bible.narrative.emotional_beat_sequence"
          },
          "visual_constraint": {
            "type": "string",
            "description": "Mandatory visual treatment for this scene, copied from the matching beat in production_bible.narrative.emotional_beat_sequence"
          },
          "start_seconds": { "type": "number", "minimum": 0 },
          "end_seconds": { "type": "number", "minimum": 0 },
          "script_section_id": { "type": "string" },
          "framing": { "type": "string" },
          "movement": { "type": "string" },
          "transition_in": { "type": "string" },
          "transition_out": { "type": "string" },
          "overlay_notes": { "type": "string" },
          "shot_language": {
            "type": "object",
            "description": "Structured cinematography vocabulary for this scene",
            "properties": {
              "shot_size": {
                "type": "string",
                "enum": ["extreme_wide", "wide", "medium_wide", "medium", "medium_close", "close_up", "extreme_close_up", "over_shoulder", "insert", "establishing"]
              },
              "camera_movement": {
                "type": "string",
                "enum": ["static", "pan_left", "pan_right", "tilt_up", "tilt_down", "dolly_in", "dolly_out", "tracking_left", "tracking_right", "crane_up", "crane_down", "handheld", "steadicam", "whip_pan", "orbital", "zoom_in", "zoom_out", "rack_focus"]
              },
              "lens_mm": { "type": "integer", "enum": [14, 24, 35, 50, 85, 135, 200] },
              "lighting_key": {
                "type": "string",
                "enum": ["high_key", "low_key", "natural", "golden_hour", "blue_hour", "tungsten_warm", "neon", "silhouette", "rim_lit", "volumetric", "overcast_soft"]
              },
              "depth_of_field": { "type": "string", "enum": ["shallow", "medium", "deep"] },
              "color_temperature": { "type": "string", "enum": ["cool", "neutral", "warm", "mixed"] }
            },
            "additionalProperties": false
          },
          "shot_intent": {
            "type": "string",
            "description": "WHY this shot exists — what purpose it serves in the video"
          },
          "narrative_role": {
            "type": "string",
            "enum": ["establish_context", "introduce_subject", "build_tension", "deliver_payload", "transition", "emotional_beat", "evidence", "comparison", "resolution", "call_to_action"],
            "description": "What role this scene plays in the narrative structure"
          },
          "information_role": {
            "type": "string",
            "description": "What the viewer learns or feels from this scene"
          },
          "hero_moment": {
            "type": "boolean",
            "default": false,
            "description": "True if this is the visual peak of the video — deserves extra attention"
          },
          "character_actions": {
            "type": "array",
            "description": "Character-specific acting beats for rigged character animation scenes",
            "items": {
              "type": "object",
              "required": ["character_id", "action_sequence"],
              "properties": {
                "character_id": { "type": "string" },
                "emotion": { "type": "string" },
                "action_sequence": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "dialogue": { "type": "string" },
                "target": { "type": "string" },
                "notes": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "texture_keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Visual texture descriptors: grain, clean, anamorphic, gritty, ethereal, etc."
          },
          "scene_type": {
            "type": "string",
            "description": "Optional fine-grained subtype used by ad-video animated/cinematic supplements (e.g. anime_scene, stat_card, text_card, callout). Free-form because the supplements add new types over time. Coexists with the coarse top-level `type` enum, which remains required."
          },
          "text": {
            "type": "string",
            "description": "Registry prop for text_card / hero_title scenes."
          },
          "brandName": {
            "type": "string",
            "description": "Registry prop for brand_card scenes."
          },
          "tagline": {
            "type": "string",
            "description": "Registry prop for brand_card scenes."
          },
          "ctaText": {
            "type": "string",
            "description": "Registry prop for brand_card scenes."
          },
          "productImage": {
            "type": "string",
            "description": "Approved product reference image for product-visible Remotion scenes such as creator_workflow_scene and brand_card."
          },
          "hardwareTreatment": {
            "type": "string",
            "enum": ["synthetic_laptop"],
            "description": "Explicit opt-in for synthetic hardware treatment. Omit unless the user approved a generic laptop packshot; productImage always takes precedence."
          },
          "leftLabel": {
            "type": "string",
            "description": "Registry prop for line_connection_scene / comparison scenes."
          },
          "rightLabel": {
            "type": "string",
            "description": "Registry prop for line_connection_scene / comparison scenes."
          },
          "leftSubLabel": {
            "type": "string",
            "description": "Registry prop for line_connection_scene scenes."
          },
          "rightSubLabel": {
            "type": "string",
            "description": "Registry prop for line_connection_scene scenes."
          },
          "targetValue": {
            "type": "number",
            "description": "Registry prop for stat_roll_scene scenes."
          },
          "unitLabel": {
            "type": "string",
            "description": "Registry prop for stat_roll_scene scenes."
          },
          "subtitle": {
            "type": "string",
            "description": "Registry prop for stat_card / stat_roll_scene scenes."
          },
          "fulfills_kvm": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Key visual moment IDs from production_bible.visual.key_visual_moments fulfilled by this scene. Empty array means this scene fulfills no mandatory KVM."
          },
          "motion_specs": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Motion primitive IDs required for this scene. For animated ad-video scenes, every value must be supported by the selected remotion-composer scene_type_registry entry."
          },
          "style_layers": {
            "type": "array",
            "items": { "type": "object" },
            "description": "Optional atmosphere/style layers for animated ad-video scenes. Layer object shapes are defined by remotion-composer/scene_type_registry.json#style_layers."
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0,
            "description": "Convenience field; equals end_seconds - start_seconds. Optional — start_seconds and end_seconds remain the canonical timing fields."
          },
          "beat": {
            "type": "string",
            "description": "Optional ad-video beat label (e.g. 'hook', 'build', 'reveal', 'cta'). Maps the scene to its production_bible.narrative.emotional_beat_sequence position."
          },
          "trend_alignment_refs": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^trend_alignment:[A-Za-z0-9._:-]+$"
            },
            "description": "Selected production_bible.intelligence.trend_alignment refs applied by this scene."
          },
          "trend_alignment_notes": {
            "type": "string",
            "minLength": 1,
            "description": "Visual or pacing instruction showing how the selected trend is adapted without copying source content."
          },
          "knowledge_alignment_refs": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^knowledge_alignment:[A-Za-z0-9._:-]+$"
            },
            "description": "Selected production_bible.intelligence.knowledge_alignment refs applied by this scene."
          },
          "knowledge_alignment_notes": {
            "type": "string",
            "minLength": 1,
            "description": "Professional producer-knowledge instruction showing how the selected doctrine shapes this scene."
          },
          "core": {
            "type": "boolean",
            "default": false,
            "description": "True if this scene must appear in the 15s_short derivative cut. When derivative_variants includes '15s', sum of core-true scene durations must be ≤ 15s."
          },
          "motion_required": {
            "type": "boolean",
            "default": false,
            "description": "True when the scene needs actual motion video (not a still). Enforces the motion-required hard rule for animated/cinematic ad-video runs."
          },
          "product_visibility": {
            "type": "string",
            "enum": ["none", "background", "partial", "hero", "detail", "packshot"],
            "description": "How visibly the advertised product appears in this scene. Product-visible generated scenes must not rely on text-only identity prompting."
          },
          "product_reference_required": {
            "type": "boolean",
            "description": "True when the scene must be conditioned on an approved product_identity_reference or an explicit risk_accepted waiver before video generation."
          },
          "hallucination_checks": {
            "type": "array",
            "minItems": 1,
            "description": "Explicit truth-contract checks the asset director must review against generated keyframes before sample approval and asset review.",
            "items": {
              "type": "object",
              "required": [
                "check_id",
                "category",
                "requirement",
                "prohibited_failure",
                "severity",
                "evidence_source"
              ],
              "additionalProperties": false,
              "properties": {
                "check_id": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Stable check id, e.g. HC-GEO-1."
                },
                "category": {
                  "type": "string",
                  "enum": [
                    "objective_fact",
                    "physical_plausibility",
                    "product_geometry",
                    "motion_coherence",
                    "values_safety"
                  ]
                },
                "requirement": {
                  "type": "string",
                  "minLength": 1
                },
                "prohibited_failure": {
                  "type": "string",
                  "minLength": 1
                },
                "severity": {
                  "type": "string",
                  "enum": ["blocker", "warning"]
                },
                "evidence_source": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Where the requirement comes from, usually production_bible.truth_contract.<section>[n] or product_identity_reference."
                }
              }
            }
          },
          "crop_regions": {
            "type": "object",
            "minProperties": 1,
            "description": "Per-aspect-ratio crop rectangles for derivative renders. Keys are aspect-ratio strings (e.g. '9:16', '1:1'); values are {x, y, w, h} pixel rectangles into the primary frame.",
            "propertyNames": {
              "enum": ["9:16", "1:1"]
            },
            "additionalProperties": {
              "type": "object",
              "required": ["x", "y", "w", "h"],
              "additionalProperties": false,
              "properties": {
                "x": { "type": "integer", "minimum": 0 },
                "y": { "type": "integer", "minimum": 0 },
                "w": { "type": "integer", "minimum": 1 },
                "h": { "type": "integer", "minimum": 1 }
              }
            }
          },
          "required_assets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "description": { "type": "string" },
                "source": { "type": "string", "enum": ["generate", "source", "provided", "record"] }
              },
              "required": ["type", "description", "source"]
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "product_visibility": {
                  "enum": ["background", "partial", "hero", "detail", "packshot"]
                }
              },
              "required": ["product_visibility"]
            },
            "then": {
              "required": ["product_reference_required"],
              "properties": {
                "product_reference_required": { "const": true }
              }
            }
          }
        ],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "metadata": { "type": "object" }
  },
  "allOf": [
    {
      "if": {
        "required": ["style_mode"],
        "properties": {
          "style_mode": { "enum": ["animated", "cinematic"] }
        }
      },
      "then": {
        "properties": {
          "scenes": {
            "items": {
              "required": [
                "core",
                "motion_required",
                "product_visibility",
                "product_reference_required"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["derivative_variants"],
        "properties": {
          "derivative_variants": { "contains": { "const": "9:16" } }
        }
      },
      "then": {
        "properties": {
          "scenes": {
            "items": {
              "required": ["crop_regions"],
              "properties": {
                "crop_regions": {
                  "required": ["9:16"]
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["derivative_variants"],
        "properties": {
          "derivative_variants": { "contains": { "const": "1:1" } }
        }
      },
      "then": {
        "properties": {
          "scenes": {
            "items": {
              "required": ["crop_regions"],
              "properties": {
                "crop_regions": {
                  "required": ["1:1"]
                }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
